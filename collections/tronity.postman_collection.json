          "request": {
            "name": "Obtain an OAuth2 access token",
            "description": {
              "content": "Exchanges credentials for a Bearer access token. Apps use grant_type \"app\" with client_id and client_secret.",
              "type": "text/plain"
            },
            "url": {
              "path": ["oauth", "authentication"],
              "host": ["{{baseUrl}}"],
              "query": [],
              "variable": []
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\",\n  \"grant_type\": \"app\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        }
      ],
      "event": []
